#!/usr/bin/env bash
# standup — Worklog-CLI. Wrapper, damit `standup` ohne venv/Aktivierung im PATH funktioniert.
# Löst Symlinks auf, sodass auch ein Symlink auf diese Datei von überall funktioniert.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"

export PYTHONPATH="${REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m standup "$@"
